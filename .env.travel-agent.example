# Core LLM
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_CHAT_MODEL=gpt-4.1-mini
SPRING_AI_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Tool provider
TRAVEL_AGENT_TOOL_PROVIDER=LOCAL
TRAVEL_AGENT_AMAP_MCP_ENABLED=false
TRAVEL_AGENT_AMAP_MCP_INITIALIZED=true
TRAVEL_AGENT_AMAP_MCP_BASE_URL=http://localhost:8090
TRAVEL_AGENT_AMAP_MCP_ENDPOINT=/mcp
TRAVEL_AGENT_AMAP_API_KEY=
TRAVEL_AGENT_AMAP_BASE_URL=https://restapi.amap.com

# Long-term memory vector
TRAVEL_AGENT_MEMORY_PROVIDER=AUTO
TRAVEL_AGENT_MILVUS_ENABLED=false
TRAVEL_AGENT_MILVUS_URI=http://localhost:19530
TRAVEL_AGENT_MILVUS_USERNAME=
TRAVEL_AGENT_MILVUS_PASSWORD=
TRAVEL_AGENT_MILVUS_DATABASE=default
TRAVEL_AGENT_MILVUS_COLLECTION=travel_agent_memory

# Knowledge vector store
TRAVEL_AGENT_KNOWLEDGE_VECTOR_ENABLED=false
TRAVEL_AGENT_KNOWLEDGE_VECTOR_URI=http://localhost:19530
TRAVEL_AGENT_KNOWLEDGE_VECTOR_USERNAME=
TRAVEL_AGENT_KNOWLEDGE_VECTOR_PASSWORD=
TRAVEL_AGENT_KNOWLEDGE_VECTOR_DATABASE_NAME=default
TRAVEL_AGENT_KNOWLEDGE_VECTOR_COLLECTION_NAME=travel_agent_knowledge
TRAVEL_AGENT_KNOWLEDGE_VECTOR_EMBEDDING_DIMENSION=256
TRAVEL_AGENT_KNOWLEDGE_VECTOR_INITIALIZE_SCHEMA=true
TRAVEL_AGENT_KNOWLEDGE_VECTOR_INDEX_TYPE=IVF_FLAT
TRAVEL_AGENT_KNOWLEDGE_VECTOR_METRIC_TYPE=COSINE
TRAVEL_AGENT_KNOWLEDGE_VECTOR_INDEX_PARAMETERS={"nlist":512}

# Backend and web
TRAVEL_AGENT_ALLOWED_ORIGIN=http://localhost:4173
VITE_AMAP_WEB_KEY=
VITE_AMAP_SECURITY_JS_CODE=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRAVEL_AGENT_TRACING_SAMPLING_PROBABILITY=1.0
